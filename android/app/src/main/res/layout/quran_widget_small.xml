<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical">

    <!-- Hero: Date — fills top half -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="start|center_vertical"
        android:background="@drawable/widget_hero_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <TextView
                android:id="@+id/widget_hijri_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15"
                android:textColor="#3A7D42"
                android:textSize="@dimen/widget_day_text_size_small"
                android:textStyle="normal"
                android:includeFontPadding="false"
                android:layout_marginBottom="1dp" />

            <TextView
                android:id="@+id/widget_hijri_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="4dp"
                android:text="Muharram"
                android:textColor="#7AAB80"
                android:textSize="@dimen/widget_month_text_size_small"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>


        <TextView
            android:id="@+id/widget_hijri_year"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1446 AH"
            android:textColor="#2A4A2E"
            android:textSize="@dimen/widget_year_text_size_small"
            android:layout_marginTop="1dp"
            android:maxLines="1" />

    </LinearLayout>

    <!-- Divider -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#162A1A"
        android:contentDescription="@null" />

    <!-- Bottom: Countdown (left) + Prayer pill (right) — always horizontal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Left: UNTIL label + countdown -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/lbl_until_small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_until"
                android:textColor="#2A4A2E"
                android:textSize="@dimen/widget_until_text_size"
                android:letterSpacing="0.1"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#8FAE92"
                android:textSize="@dimen/widget_countdown_text_size_small"
                android:textStyle="normal"
                android:includeFontPadding="false"
                android:layout_marginTop="1dp"
                android:maxLines="1" />

        </LinearLayout>

        <!-- Right: Prayer name pill -->
        <TextView
            android:id="@+id/widget_next_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="---"
            android:textColor="#4A7A50"
            android:textSize="@dimen/widget_next_name_text_size"
            android:maxLines="1"
            android:background="@drawable/widget_pill_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

    </LinearLayout>

</LinearLayout>