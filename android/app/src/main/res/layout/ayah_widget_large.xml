<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background">

    <!-- Reference Section - Pinned to top right -->
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:padding="12dp">

        <TextView
            android:id="@+id/widget_ayah_reference"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Surah Al-Fatihah 1:1"
            android:textColor="#81C784"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />
    </RelativeLayout>

    <!-- Translation Section - Truly Centered -->
    <TextView
        android:id="@+id/widget_ayah_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="28dp"
        android:gravity="center"
        android:text="In the name of Allah, the Entirely Merciful, the Especially Merciful."
        android:textColor="#E8F5E9"
        android:textSize="15sp" />

    <!-- Attribution - Kept for ID compatibility but hidden/empty -->
    <TextView
        android:id="@+id/widget_ayah_attribution"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <ImageButton
        android:id="@+id/btn_reload_ayah"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="8dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_reload"
        android:scaleType="fitCenter"
        android:contentDescription="Reload Ayah" />

</FrameLayout>
